# =============================================================================
# NEUQA PR Agent — Environment template
# =============================================================================
# Copy to .env and fill in values. Never commit .env or put real secrets here.
# See docs/CONFIGURATION.md for full reference.
# =============================================================================

# --- Required ---
REPO_URL=https://github.com/org/repo
FOUNDRY_BASE_URL=http://127.0.0.1:56077/openai/v1
FOUNDRY_MODEL=phi-4

# --- MCP: choose one mode ---
# Remote MCP (primary)
MCP_SERVER_URL=https://api.githubcopilot.com/mcp/
# MCP_AUTH_TOKEN=<bearer-token-if-required>
# REPO_ACCESS_TOKEN is used when MCP_AUTH_TOKEN is not set

# Stdio MCP (e.g. Docker) — use when MCP_SERVER_URL is not set
# MCP_TRANSPORT=stdio
# MCP_STDIO_COMMAND=docker
# MCP_STDIO_ARGS=run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN=<token> ghcr.io/github/github-mcp-server stdio --toolsets=all

# --- Secrets (set in .env or CI secrets; never commit) ---
# REPO_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# WEBHOOK_SECRET=<webhook-secret-for-signature-verification>
# FOUNDRY_API_KEY=

# --- Optional: behavior and paths ---
# POLL_INTERVAL_SECONDS=60
# STATE_DB_PATH=.neuqa_state.json
# REVIEW_STATE_PATH=.neuqa_state.json
# LOG_LEVEL=info
# MCP_READONLY=false
# PROMPT_EXTRA=Focus on security and test coverage.
# REVIEW_INCREMENTAL=false
# REVIEW_SKIP_SIMPLE=false
# REVIEW_SIMPLE_MAX_LINES=40
# REVIEW_MAX_CONCURRENCY=6
# REVIEW_MAX_FILES=

# --- Optional: Postgres state backend ---
# STATE_BACKEND=file
# STATE_BACKEND=postgres
# DATABASE_URL=postgresql://user:pass@host/db
